# Normalize line endings so macOS (LF) and Windows checkouts stay clean.
* text=auto eol=lf

# Source files: always LF
*.py   text eol=lf
*.xml  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary assets — never touch / never diff
*.wotmod binary
*.pyc    binary
*.dds    binary
*.png    binary
*.jpg    binary
*.dds    binary
*.swf    binary
*.usm    binary
