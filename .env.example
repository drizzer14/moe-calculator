# Copy this file to `.env` (gitignored) and fill in your Wargaming API application_id.
#
# Get one at https://developers.wargaming.net/applications/ (Standard application, any type).
# build/build_wotmod.py reads this value and injects it into the packaged .wotmod's
# moe_calculator/build_config.py at build time -- so the id lives only in the built package,
# never in source control. Without it, the build still succeeds but the mod cannot fetch MoE
# thresholds (the bar degrades to ticks without per-mark damage labels).
WG_APPLICATION_ID=
