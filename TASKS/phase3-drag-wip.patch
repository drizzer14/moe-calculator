diff --git a/src/res/scripts/client/moe_calculator/bridge/battle_drag.py b/src/res/scripts/client/moe_calculator/bridge/battle_drag.py
new file mode 100644
index 0000000..329c2ad
--- /dev/null
+++ b/src/res/scripts/client/moe_calculator/bridge/battle_drag.py
@@ -0,0 +1,236 @@
+# -*- coding: utf-8 -*-
+"""Ctrl+drag the in-battle overlay -- driven ENTIRELY from Python.
+
+Why not JS drag: the overlay is a content-sized, input-transparent Gameface WINDOW
+(show(focus=False), pointer-events:none) so it never steals the battle HUD's mouse
+hit-test. That same input-transparency means its DOM receives NO pointer events, and a
+plain JS console.log isn't routed to python.log -- so a JS-side drag can neither observe
+input nor report reliably (verified in-client 2026-07-08). Instead we poll the engine
+directly on the MAIN thread and move() the WINDOW ourselves.
+
+Gesture: hold Ctrl (WG shows the mouse cursor in battle while Ctrl is held) + press Left
+Mouse while the cursor is over the overlay, then drag; on release the position is persisted
+as a scale/resolution-independent FRACTION via mod_settings. Ctrl is NOT hijacked -- we only
+begin a drag on a fresh Ctrl+LMB press whose cursor is inside the overlay's rect, and we
+never consume the input (a read-only poll), so aiming / other Ctrl uses are unaffected.
+
+All primitives VERIFIED live via the debug REPL (2.3.0.1):
+  - BigWorld.isKeyDown(Keys.KEY_LCONTROL/RCONTROL/LEFTMOUSE) -> reads Ctrl + LMB (incl. together).
+  - GUI.mcursor().position -> the cursor in CLIP space: x in [-1,1] left->right, y in [-1,1]
+    BOTTOM->top (so y is flipped to screen space). Updates live; cursor visible under Ctrl.
+  - GUI.screenResolution() / interfaceScale.get() -> the logical GUI space (physical / scale);
+    matches the far-sentinel movable extent used by battle_view._place exactly.
+  - window.move()/position/size -> the overlay is a fixed 256x256 surface (size read-only).
+The poll is armed on battle mount and disarmed on teardown (battle_bridge); a self-
+re-registering BigWorld.callback on the main thread (the REPL thread's callbacks do NOT
+run -- that's a REPL limitation, not the mod's). Python 2.7 runtime; PC-only (not imported
+under pytest -- the pure fraction math lives in domain/wulf_args).
+"""
+import BigWorld
+import Keys
+import GUI
+
+from frameworks.wulf import PositionAnchor
+from moe_calculator._compat import LOG_CURRENT_EXCEPTION, LOG_NOTE
+
+# Poll cadence. ~33 Hz is smooth for the drag and negligible when idle (2 isKeyDown reads
+# per tick until Ctrl is held). Only armed during a battle, so it never runs in the garage.
+_POLL_INTERVAL = 0.03
+
+# Module state. `gen` makes arm() idempotent: each arm bumps it so any older poll loop exits
+# and exactly one runs. `grab` is the cursor's offset from the window top-left at drag start.
+_state = {"armed": False, "gen": 0, "dragging": False, "lmb_prev": False, "grab": (0, 0),
+          "dbg_tick": 0, "dbg_ctrl_prev": False, "dbg_lmb_prev": False}
+
+# Diagnostic (Phase 3 drag bring-up). The gesture never fired in the first live test though the
+# poll loop DID run; every failure hypothesis reduces to "is _over True when the user Ctrl+LMBs
+# on the visible overlay?" -- which was never observed. So log the full gesture state, throttled
+# so it never floods python.log: ~1/s while Ctrl is held, PLUS unconditionally at the decisive
+# moment a fresh LMB press lands under Ctrl. One Ctrl+LMB-drag over the overlay then reveals
+# whether the clip->logical cursor maps inside the window rect. Flip _DEBUG off (or delete this
+# block + its call) once the gesture is confirmed.
+_DEBUG = True
+_DBG_EVERY = 33  # ticks (~1s at _POLL_INTERVAL)
+
+# Cached ISettingsCore (for interfaceScale); resolved once, reused every tick.
+_settings_core = [None]
+
+
+def _ctrl_down():
+    return bool(BigWorld.isKeyDown(Keys.KEY_LCONTROL) or BigWorld.isKeyDown(Keys.KEY_RCONTROL))
+
+
+def _lmb_down():
+    return bool(BigWorld.isKeyDown(Keys.KEY_LEFTMOUSE))
+
+
+def _scale():
+    """Interface scale (float, e.g. 1.0/2.0), fail-soft to 1.0. Cached core."""
+    try:
+        if _settings_core[0] is None:
+            from moe_calculator.adapter import battle_adapter
+            _settings_core[0] = battle_adapter._settings_core()
+        core = _settings_core[0]
+        if core is not None:
+            s = core.interfaceScale.get()
+            if s:
+                return s
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+    return 1.0
+
+
+def _logical_size():
+    """The logical GUI space (physical px / interfaceScale) -- the space move() works in.
+    Computed directly (NOT via the far-sentinel clamp, which would fling the window mid-drag)
+    and equal to it: screenResolution/scale - surface == battle_view's far-sentinel extent."""
+    sw, sh = GUI.screenResolution()
+    s = _scale()
+    return sw / s, sh / s
+
+
+def _cursor_logical(lw, lh):
+    """Cursor (clip space) -> logical GUI px. Clip x in [-1,1] left->right, y in [-1,1]
+    BOTTOM->top; screen y grows downward, so y is flipped."""
+    cx, cy = GUI.mcursor().position
+    return (cx + 1.0) * 0.5 * lw, (1.0 - cy) * 0.5 * lh
+
+
+def _active_window():
+    from moe_calculator.bridge import battle_view
+    active = battle_view._active
+    return active[0] if active is not None else None
+
+
+def _over(win, lx, ly, ww, wh):
+    wx, wy = win.position
+    return wx <= lx <= wx + ww and wy <= ly <= wy + wh
+
+
+def _heartbeat_alive(win, lctrl, rctrl, lmb):
+    """Unconditional, throttled probe run at the TOP of every poll -- proves the callback chain
+    is actually TICKING (not merely armed) and shows raw input state, regardless of the
+    early-return below. Fires ~1/s AND on any ctrl/lmb edge, so the exact Ctrl-hold / LMB-click
+    is captured. Guarded: a diagnostic must never break the poll."""
+    if not _DEBUG:
+        return
+    try:
+        ctrl = lctrl or rctrl
+        edge = (ctrl != _state["dbg_ctrl_prev"]) or (lmb != _state["dbg_lmb_prev"])
+        _state["dbg_ctrl_prev"] = ctrl
+        _state["dbg_lmb_prev"] = lmb
+        if not (edge or _state["dbg_tick"] % _DBG_EVERY == 0):
+            return
+        LOG_NOTE("[moe-battle][dbg] alive tick=%d lctrl=%s rctrl=%s lmb=%s win=%s"
+                 % (_state["dbg_tick"], lctrl, rctrl, lmb, win is not None))
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _heartbeat_over(win, ctrl, lmb, lw, lh, ww, wh, lx, ly, over):
+    """Richer gesture-state dump, reached only past the Ctrl-gated early-return. Logs at the
+    decisive fresh-Ctrl+LMB-press moment AND ~1/s while Ctrl is held, so we see whether the
+    clip->logical cursor maps inside the window rect. Guarded."""
+    if not _DEBUG:
+        return
+    try:
+        fresh_press = ctrl and lmb and not _state["lmb_prev"]
+        if not (fresh_press or _state["dbg_tick"] % _DBG_EVERY == 0):
+            return
+        cx, cy = GUI.mcursor().position
+        LOG_NOTE("[moe-battle][dbg] over ctrl=%s lmb=%s fresh=%s clip=%.3f,%.3f logical=%.0f,%.0f "
+                 "space=%.0fx%.0f win.pos=%s win.size=%s over=%s drag=%s"
+                 % (ctrl, lmb, fresh_press, cx, cy, lx, ly, lw, lh,
+                    win.position, (ww, wh), over, _state["dragging"]))
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _poll_once():
+    # Heartbeat FIRST, before any early-return, so a total absence of [dbg] lines means the poll
+    # isn't ticking at all (vs. ticking-but-Ctrl-never-detected). Read the raw key states here so
+    # the alive log reports them directly.
+    _state["dbg_tick"] += 1
+    win = _active_window()
+    lctrl = bool(BigWorld.isKeyDown(Keys.KEY_LCONTROL))
+    rctrl = bool(BigWorld.isKeyDown(Keys.KEY_RCONTROL))
+    ctrl = lctrl or rctrl
+    lmb = _lmb_down()
+    _heartbeat_alive(win, lctrl, rctrl, lmb)
+    # Idle fast-path: the gesture needs Ctrl, so do nothing (but keep edge tracking honest)
+    # until Ctrl is held or a drag is in progress.
+    if win is None or (not ctrl and not _state["dragging"]):
+        _state["lmb_prev"] = lmb
+        return
+    lw, lh = _logical_size()
+    ww, wh = win.size
+    max_x = max(0, int(lw - ww))
+    max_y = max(0, int(lh - wh))
+    lx, ly = _cursor_logical(lw, lh)
+    over = _over(win, lx, ly, ww, wh)
+    _heartbeat_over(win, ctrl, lmb, lw, lh, ww, wh, lx, ly, over)
+    if not _state["dragging"]:
+        # Begin only on a FRESH Ctrl+LMB press whose cursor is over the overlay (so we never
+        # hijack Ctrl+LMB used elsewhere).
+        if ctrl and lmb and not _state["lmb_prev"] and over:
+            wx, wy = win.position
+            _state["dragging"] = True
+            _state["grab"] = (lx - wx, ly - wy)
+            LOG_NOTE("[moe-battle] drag start cursor=%d,%d win=%s" % (lx, ly, win.position))
+    else:
+        if not (ctrl and lmb):
+            _end_drag(win, max_x, max_y)
+        else:
+            gx, gy = _state["grab"]
+            nx = min(max(0, int(round(lx - gx))), max_x)
+            ny = min(max(0, int(round(ly - gy))), max_y)
+            win.move(nx, ny, xAnchor=PositionAnchor.LEFT, yAnchor=PositionAnchor.TOP)
+    _state["lmb_prev"] = lmb
+
+
+def _end_drag(win, max_x, max_y):
+    _state["dragging"] = False
+    wx, wy = win.position
+    fx = (wx / float(max_x)) if max_x else 0.0
+    fy = (wy / float(max_y)) if max_y else 0.0
+    LOG_NOTE("[moe-battle] drag end win=%s frac=%.3f,%.3f -> persist" % (win.position, fx, fy))
+    try:
+        from moe_calculator.bridge import mod_settings
+        mod_settings.set_battle_position(fx, fy)
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _tick(gen):
+    # A stale generation (a newer arm()) or disarm() ends this loop.
+    if not _state["armed"] or gen != _state["gen"]:
+        return
+    try:
+        _poll_once()
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+    try:
+        BigWorld.callback(_POLL_INTERVAL, lambda: _tick(gen))
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def arm():
+    """Start the drag poll on the main thread. Idempotent: bumps the generation so any prior
+    loop exits and exactly one runs. Call on battle mount (avatar ready)."""
+    _state["gen"] += 1
+    _state["armed"] = True
+    _state["dragging"] = False
+    _state["lmb_prev"] = False
+    g = _state["gen"]
+    try:
+        BigWorld.callback(0.0, lambda: _tick(g))
+        LOG_NOTE("[moe-battle] drag poll armed (gen=%d)" % g)
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def disarm():
+    """Stop the drag poll. Call on battle teardown."""
+    _state["armed"] = False
+    _state["dragging"] = False
