+    assert w.clamp_frac(float("nan")) == 0.0
diff --git a/tests/test_position.py b/tests/test_position.py
new file mode 100644
index 0000000..913e0f2
--- /dev/null
+++ b/tests/test_position.py
@@ -0,0 +1,138 @@
+# -*- coding: utf-8 -*-
+"""Unit tests for the in-battle overlay position storage (clamp + fraction round-trip +
+reset). Runs on Python 3 (no game engine): clamp_permille / battle_frac are pure, and the
+MSA / battle_view calls inside set_battle_position / _on_reset degrade to guarded no-ops
+when neither the settings API nor frameworks.wulf is importable in the test env."""
+from moe_calculator.bridge import mod_settings
+
+
+def test_clamp_permille_passthrough_in_range():
+    assert mod_settings.clamp_permille(0) == 0
+    assert mod_settings.clamp_permille(1) == 1
+    assert mod_settings.clamp_permille(500) == 500
+    assert mod_settings.clamp_permille(mod_settings.FRAC_MAX) == mod_settings.FRAC_MAX
+
+
+def test_clamp_permille_negative_becomes_auto():
+    assert mod_settings.clamp_permille(-1) == 0
+    assert mod_settings.clamp_permille(-9999) == 0
+
+
+def test_clamp_permille_over_max_is_capped():
+    assert mod_settings.clamp_permille(mod_settings.FRAC_MAX + 1) == mod_settings.FRAC_MAX
+    assert mod_settings.clamp_permille(10 ** 9) == mod_settings.FRAC_MAX
+
+
+def test_clamp_permille_non_numeric_becomes_zero():
+    assert mod_settings.clamp_permille(None) == 0
+    assert mod_settings.clamp_permille("nope") == 0
+    assert mod_settings.clamp_permille([1, 2]) == 0
+
+
+def test_clamp_permille_floats_truncate():
+    assert mod_settings.clamp_permille(12.9) == 12
+    assert mod_settings.clamp_permille("37") == 37
+
+
+def test_defaults_are_auto():
+    assert mod_settings.DEFAULTS["posX"] == 0
+    assert mod_settings.DEFAULTS["posY"] == 0
+
+
+def test_battle_frac_is_none_when_auto():
+    mod_settings._settings["posX"] = 0
+    mod_settings._settings["posY"] = 0
+    assert mod_settings.battle_frac() is None
+
+
+def test_battle_frac_is_none_when_only_one_axis_set():
+    # Both axes must be set for a valid stored position (a real drag floors both to >=1).
+    mod_settings._settings["posX"] = 500
+    mod_settings._settings["posY"] = 0
+    assert mod_settings.battle_frac() is None
+
+
+def test_battle_frac_returns_fractions_when_set():
+    mod_settings._settings["posX"] = 500
+    mod_settings._settings["posY"] = 250
+    fx, fy = mod_settings.battle_frac()
+    assert abs(fx - 0.5) < 1e-9
+    assert abs(fy - 0.25) < 1e-9
+
+
+def test_set_battle_position_stores_permille():
+    mod_settings._settings["posX"] = 0
+    mod_settings._settings["posY"] = 0
+    mod_settings.set_battle_position(0.5, 0.25)   # MSA / re-place calls no-op in test env
+    assert mod_settings._settings["posX"] == 500
+    assert mod_settings._settings["posY"] == 250
+
+
+def test_set_battle_position_floors_corner_at_one():
+    # A flush-to-corner drag (fraction 0.0) must NOT collapse into the 0 == "auto" sentinel;
+    # it floors to per-mille 1 so battle_frac still reports a real (non-auto) position.
+    mod_settings._settings["posX"] = 0
+    mod_settings._settings["posY"] = 0
+    mod_settings.set_battle_position(0.0, 0.0)
+    assert mod_settings._settings["posX"] == 1
+    assert mod_settings._settings["posY"] == 1
+    assert mod_settings.battle_frac() is not None
+
+
+def test_set_battle_position_clamps_out_of_range():
+    mod_settings.set_battle_position(2.0, -1.0)   # clamp_frac -> (1.0, 0.0) -> (1000, 1)
+    assert mod_settings._settings["posX"] == mod_settings.FRAC_MAX
+    assert mod_settings._settings["posY"] == 1
+
+
+def test_on_reset_ignores_other_mods():
+    # onResetMod is a global event across every mod; our handler must only act on our own
+    # linkage (else another mod's reset would wipe our position).
+    mod_settings._settings["posX"] = 999
+    mod_settings._settings["posY"] = 888
+    mod_settings._on_reset("some.other.mod", {"posX": 0, "posY": 0})
+    assert mod_settings._settings["posX"] == 999
+    assert mod_settings._settings["posY"] == 888
+
+
+def test_on_reset_returns_own_mod_to_auto():
+    mod_settings._settings["posX"] = 700
+    mod_settings._settings["posY"] = 300
+    mod_settings._on_reset(mod_settings.LINKAGE, {"posX": 500, "posY": 500})
+    assert mod_settings._settings["posX"] == 0
+    assert mod_settings._settings["posY"] == 0
+
+
+class _FakeApi(object):
+    """Minimal stand-in for g_modsSettingsApi.getModSettings."""
+    def __init__(self, stored):
+        self._stored = stored
+
+    def getModSettings(self, linkage, template):
+        return self._stored
+
+
+def test_full_settings_preserves_host_enabled_key():
+    # updateModSettings REPLACES the stored dict, so a partial write would drop Aslain's
+    # 'enabled' toggle and blank the whole panel. The full-write must keep 'enabled' (and
+    # honor its stored value) while overlaying our own varNames.
+    mod_settings._settings["posX"] = 111
+    mod_settings._settings["posY"] = 222
+    stored = {"enabled": False, "posX": 5, "posY": 6}
+    out = mod_settings._full_settings_for_write(_FakeApi(stored))
+    assert out["enabled"] is False          # host toggle preserved
+    assert out["posX"] == 111 and out["posY"] == 222   # our live values overlaid
+    for k in ("posX", "posY", "enabled"):
+        assert k in out
+
+
+def test_full_settings_defaults_enabled_when_missing():
+    out = mod_settings._full_settings_for_write(_FakeApi({"posX": 0}))
+    assert out["enabled"] is True
+
+
+def test_full_settings_handles_no_stored():
+    out = mod_settings._full_settings_for_write(_FakeApi(None))
+    assert out["enabled"] is True
+    for k in ("posX", "posY"):
+        assert k in out
