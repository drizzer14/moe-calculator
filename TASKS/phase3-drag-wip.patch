index 0000000..337fe66
--- /dev/null
+++ b/src/res/scripts/client/moe_calculator/bridge/mod_settings.py
@@ -0,0 +1,314 @@
+# -*- coding: utf-8 -*-
+"""User settings for the in-battle overlay, surfaced through ModsSettingsAPI (the
+community settings panel).
+
+ModsSettingsAPI (izeberg.modssettingsapi, also shipped by Aslain's modpack) is an
+OPTIONAL dependency: we import it guarded, and if it's absent the overlay simply keeps
+its computed default position with no settings panel -- never a crash. MSA owns
+persistence, so there's no config file of our own. (izeberg.modssettingsapi_1.7.0 IS
+vendored in installer/vendor/, so it's present in the shipped bundle.)
+
+The ONLY setting here is the overlay's draggable position, stored as two PER-MILLE
+coordinates of the logical GUI space (0..1000 == 0.0..1.0 of the movable extent):
+- posX -- the window's LEFT, as a fraction of the horizontal movable extent.
+- posY -- the window's TOP,  as a fraction of the vertical movable extent.
+Both default to 0, which means "auto": the overlay keeps its computed default anchor
+(bridge/battle_view._place -> the damage-log-aware BATTLE_ANCHOR_*, Phase 1/2), which is
+interface-scale- AND resolution-invariant. posX/posY stay 0 until the user actually moves
+the panel (Ctrl+drag in battle, or the numeric steppers); a real placement pins the
+chosen fraction and TAKES OVER from the auto anchor (manual override wins -- the
+damage-log auto-raise no longer applies while a custom position is set). Reset returns
+to auto, so the computed anchor (and its damage-log awareness) resumes.
+
+WHY fractions, not pixels: the overlay window is positioned in the engine's LOGICAL GUI
+space, whose size changes with interface scale (1920x1080 @2x vs 3840x2160 @1x) and
+resolution. A fraction of the movable extent re-derives to the same relative spot at any
+scale/resolution; a stored pixel would freeze one layout and drift everywhere else. The
+floor-at-1 rule (see set_battle_position) keeps a flush-to-corner drag from collapsing
+into the 0 == "auto" sentinel.
+
+Reset uses the settings panel's OWN "reset to defaults" button (Aslain's per-mod reset),
+which fires the api's `onResetMod` event -- NOT `onSettingsChanged`. So we subscribe to
+onResetMod (_on_reset) and reset the position to auto there.
+
+Unlike the garage sibling this was ported from, a settings change RE-PLACES the overlay
+window (battle_view.apply_position, which move()s the window) rather than re-pushing a
+data model -- in battle the position lives in the window geometry, not the CSS.
+"""
+from moe_calculator._compat import LOG_CURRENT_EXCEPTION, LOG_NOTE
+
+# Our mod's reverse-domain id, reused as the MSA "linkage" (panel identity / storage key).
+LINKAGE = "com.14th_ua.moe_calculator"
+
+# Per-mille scale: a stored coordinate is an int in [0, FRAC_MAX], where FRAC_MAX maps to
+# 1.0 (the far edge of the movable extent). 0 is reserved as the "auto / unmoved" sentinel.
+FRAC_MAX = 1000
+
+DEFAULTS = {"posX": 0, "posY": 0}
+
+
+def clamp_permille(v):
+    """Coerce a stored position coordinate to an int in [0, FRAC_MAX]. 0 = auto/unmoved.
+    Pure + engine-free (unit-tested); non-numeric / negative -> 0."""
+    try:
+        v = int(v)
+    except (TypeError, ValueError):
+        return 0
+    if v < 0:
+        return 0
+    if v > FRAC_MAX:
+        return FRAC_MAX
+    return v
+
+
+# Current effective settings. Starts at defaults so accessors are always safe to call,
+# even before init() runs or when MSA is absent.
+_settings = dict(DEFAULTS)
+
+# True once we've successfully registered with MSA. Kept so init() is idempotent AND
+# self-healing: a failed attempt (MSA not loaded yet at our import time) leaves this
+# False, so a later init() call (first battle mount) retries until it sticks.
+_registered = False
+
+
+def _template():
+    """The MSA panel descriptor: a short explainer + two numeric steppers (per-mille of
+    screen, 0 = auto). Ctrl+drag in battle is the primary control; the steppers are a
+    fallback for exact placement / when drag is unavailable. Reset is the panel's own
+    per-mod reset button (see _on_reset), so there is no custom reset control here."""
+    return {
+        "modDisplayName": "14th_ua's MoE Calculator",
+        "enabled": True,
+        # settingsVersion lets the panel preserve the user's saved values across cosmetic
+        # template edits (label/tooltip tweaks): the host only wipes stored settings to
+        # defaults when this number is BUMPED. Bump it whenever the set of varNames / the
+        # control layout changes (not for text-only edits). Verified against the Aslain
+        # 1.3.2 + izeberg 1.7.0 compareTemplates bytecode.
+        "settingsVersion": 1,
+        "column1": [
+            {
+                "type": "Label",
+                "text": "In-battle overlay position",
+                "tooltip": ("{HEADER}In-battle overlay position{/HEADER}"
+                            "{BODY}Ctrl+drag the MoE overlay in battle to move it, or type "
+                            "exact coordinates below (per-mille of the screen, so 500 is the "
+                            "middle). Leave both at 0 for the automatic position that tracks "
+                            "the efficiency panel. Reset returns it to automatic.{/BODY}"),
+            },
+            {
+                "type": "NumericStepper",
+                "text": "Horizontal (0 = auto, 1000 = right edge)",
+                "value": DEFAULTS["posX"],
+                "minimum": 0,
+                "maximum": FRAC_MAX,
+                "snapInterval": 1,
+                "canManualInput": True,
+                "tooltip": ("{HEADER}Horizontal position{/HEADER}"
+                            "{BODY}The overlay's left edge, in per-mille of the screen width "
+                            "(0 = automatic, 500 = middle, 1000 = right edge).{/BODY}"),
+                "varName": "posX",
+            },
+            {
+                "type": "NumericStepper",
+                "text": "Vertical (0 = auto, 1000 = bottom edge)",
+                "value": DEFAULTS["posY"],
+                "minimum": 0,
+                "maximum": FRAC_MAX,
+                "snapInterval": 1,
+                "canManualInput": True,
+                "tooltip": ("{HEADER}Vertical position{/HEADER}"
+                            "{BODY}The overlay's top edge, in per-mille of the screen height "
+                            "(0 = automatic, 500 = middle, 1000 = bottom edge).{/BODY}"),
+                "varName": "posY",
+            },
+        ],
+    }
+
+
+def _apply(settings):
+    """Merge an MSA settings dict into our cache, ignoring unknown/missing keys. Both
+    position fields are clamped per-mille ints."""
+    if not settings:
+        return
+    for key in DEFAULTS:
+        if key in settings:
+            _settings[key] = clamp_permille(settings[key])
+
+
+def init():
+    """Register (or re-load) our settings panel with ModsSettingsAPI.
+
+    Idempotent and self-healing: a no-op once registered; otherwise re-attempts. MSA may
+    load after us at startup, so the import can fail on the first call from the entry
+    point -- we then retry on the first battle mount (battle_bridge), by which point every
+    mod is loaded. Guarded so it never raises into the mount path."""
+    global _registered
+    if _registered:
+        return
+    try:
+        from gui.modsSettingsApi import g_modsSettingsApi
+    except ImportError:
+        LOG_NOTE("[moe] ModsSettingsAPI not present -- overlay uses its automatic "
+                 "position (no settings panel)")
+        return
+    try:
+        template = _template()
+        saved = g_modsSettingsApi.getModSettings(LINKAGE, template)
+        if saved:
+            _apply(saved)
+            g_modsSettingsApi.registerCallback(LINKAGE, _on_changed)
+            # Repair a settings dict missing the host-managed 'enabled' key (an earlier
+            # partial updateModSettings write could drop it, which makes Aslain's panel
+            # renderer KeyError and blank every mod's settings). No-op for a healthy install.
+            if "enabled" not in saved:
+                g_modsSettingsApi.updateModSettings(
+                    LINKAGE, _full_settings_for_write(g_modsSettingsApi))
+                try:
+                    g_modsSettingsApi.saveState()
+                except Exception:
+                    LOG_CURRENT_EXCEPTION()
+                LOG_NOTE("[moe] repaired settings (re-added 'enabled')")
+        else:
+            _apply(g_modsSettingsApi.setModTemplate(LINKAGE, template, _on_changed))
+        # Wire the panel's "reset to defaults" button. It fires onResetMod (NOT
+        # onSettingsChanged), on whichever api actually stores this client's settings.
+        # With Aslain installed our data lives in Aslain's api (a SEPARATE object from the
+        # izeberg api we import here, and the one that has onResetMod), so subscribe on
+        # BOTH (de-duped, guarded); pure-izeberg installs skip the one without onResetMod.
+        _subscribe_reset(g_modsSettingsApi)
+        try:
+            from gui.aslainMenu import g_modsSettingsApi as _aslain_api
+            _subscribe_reset(_aslain_api)
+        except Exception:
+            pass
+        _registered = True
+        LOG_NOTE("[moe] ModsSettingsAPI registered: %s" % (_settings,))
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _on_changed(linkage, new_settings):
+    """MSA callback when the user changes a setting (e.g. edits a stepper). Update the
+    cache and RE-PLACE the overlay window so the change applies live."""
+    try:
+        _apply(new_settings)
+        LOG_NOTE("[moe] settings changed: %s" % (_settings,))
+        _reapply_position()
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+# Object ids of api instances we've already hooked onResetMod on, so init() retries
+# (entry point + every battle mount) never stack duplicate handlers.
+_reset_hooked = set()
+
+
+def _subscribe_reset(api):
+    """Subscribe _on_reset to an api's onResetMod event (the panel 'reset to defaults'
+    button), de-duped by object id. No-op if the api lacks onResetMod (pure izeberg) or is
+    already hooked. Guarded so a settings-API shape change can't break registration."""
+    try:
+        if api is None or not hasattr(api, "onResetMod"):
+            return
+        if id(api) in _reset_hooked:
+            return
+        api.onResetMod += _on_reset
+        _reset_hooked.add(id(api))
+        LOG_NOTE("[moe] onResetMod hooked on %s" % (type(api).__module__,))
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _on_reset(linkage, defaults):
+    """Panel 'reset to defaults' button. The settings host fires onResetMod (NOT
+    onSettingsChanged) when the user resets a mod. Force the position back to AUTO (0/0) --
+    the computed anchor (and its damage-log awareness) then resumes -- regardless of what
+    the host snapshot carries. Guarded + linkage-scoped (the event is global across every
+    mod)."""
+    try:
+        if linkage != LINKAGE:
+            return
+        _settings["posX"] = 0
+        _settings["posY"] = 0
+        LOG_NOTE("[moe] onResetMod -> position reset to auto")
+        _reapply_position()
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _full_settings_for_write(g_modsSettingsApi):
+    """Build the COMPLETE settings dict to hand to updateModSettings.
+
+    updateModSettings *replaces* the whole stored per-linkage dict (verified against the
+    MSA 1.7.0 AND Aslain 1.3.2 bytecode), so a partial dict silently drops keys the host
+    owns -- notably Aslain's per-mod 'enabled' toggle, whose renderer indexes
+    settings['enabled'] (a missing key KeyErrors and blanks the ENTIRE panel, every mod).
+    So start from the currently-stored settings (preserving 'enabled' and any other host
+    keys), guarantee 'enabled' exists (default True), then overlay our own varNames."""
+    data = {}
+    try:
+        current = g_modsSettingsApi.getModSettings(LINKAGE, _template())
+        if current:
+            data = dict(current)
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+    data.setdefault("enabled", True)   # host-managed per-mod toggle; never drop it
+    data.update(_settings)             # our varNames (posX/posY)
+    return data
+
+
+def set_battle_position(fx, fy):
+    """Persist a new overlay position (given as 0..1 fractions of the movable extent) and
+    re-place the window. Called from bridge/battle_drag on drop of a Ctrl+drag.
+
+    The fractions are stored as per-mille ints, FLOORED at 1 so a flush-to-corner drag
+    (fraction 0.0) doesn't collapse into the 0 == "auto" sentinel and get discarded on the
+    next placement. Writes the FULL settings through ModsSettingsAPI so the panel's numeric
+    fields track the position; guarded so a missing/broken MSA never breaks the overlay.
+    updateModSettings only mutates in-memory state, so saveState() flushes it to disk
+    (survives a client restart)."""
+    from moe_calculator.bridge import wulf_args
+    px = max(1, int(round(wulf_args.clamp_frac(fx) * FRAC_MAX)))
+    py = max(1, int(round(wulf_args.clamp_frac(fy) * FRAC_MAX)))
+    _settings["posX"] = clamp_permille(px)
+    _settings["posY"] = clamp_permille(py)
+    _persist()
+    _reapply_position()
+
+
+def _persist():
+    """Flush the current settings to MSA (in-memory replace + saveState to disk). Guarded;
+    a missing MSA means the position still applies this session, just isn't persisted."""
+    try:
+        from gui.modsSettingsApi import g_modsSettingsApi
+        g_modsSettingsApi.updateModSettings(LINKAGE, _full_settings_for_write(g_modsSettingsApi))
+        try:
+            g_modsSettingsApi.saveState()
+        except Exception:
+            LOG_CURRENT_EXCEPTION()
+    except ImportError:
+        pass
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def _reapply_position():
+    """Re-place the open overlay window at the (possibly new) position. Lazy import avoids
+    a battle_view <-> mod_settings import cycle; a no-op when the overlay is closed."""
+    try:
+        from moe_calculator.bridge import battle_view
+        battle_view.apply_position()
+    except Exception:
+        LOG_CURRENT_EXCEPTION()
+
+
+def battle_frac():
+    """The user-set overlay position as (fx, fy) fractions of the movable extent, or None
+    when unset (auto). None tells battle_view._place to use the computed damage-log-aware
+    anchor instead. A real placement floors both coords to >=1 per-mille, so 'both > 0' is
+    the reliable 'user has moved it' test."""
+    px = _settings["posX"]
+    py = _settings["posY"]
+    if px > 0 and py > 0:
+        return px / float(FRAC_MAX), py / float(FRAC_MAX)
+    return None
