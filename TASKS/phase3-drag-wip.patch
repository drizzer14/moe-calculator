+
+def clamp_frac(v):
+    """Coerce a screen-position FRACTION to a float in [0.0, 1.0]. Pure + engine-free
+    (unit-tested); non-numeric / out-of-range collapses into the range (non-numeric -> 0.0).
+
+    The in-battle overlay persists its Ctrl+dragged position as fractions of the logical GUI
+    space (resolution- and interface-scale-independent, unlike raw pixels) -- see
+    bridge/mod_settings.py (set_battle_position) and bridge/battle_drag.py."""
+    try:
+        v = float(v)
+    except (TypeError, ValueError):
+        return 0.0
+    if v != v:          # NaN (NaN != NaN) -> auto
+        return 0.0
+    if v < 0.0:
+        return 0.0
+    if v > 1.0:
+        return 1.0
+    return v
